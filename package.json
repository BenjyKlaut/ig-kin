{
  "name": "ig-kin",
  "version": "1.0.0",
  "description": "IG-Kin - Application desktop",
  "private": true,
  "main": "electron-main.js",
  "scripts": {
    "build:ui": "cd client/react && npm run build",
    "start:electron": "electron .",
    "dist": "npm run build:ui && npx electron-builder --publish=never",
    "clean": "rimraf dist node_modules"
  },
  "build": {
    "appId": "com.igpnc.igkin",
    "productName": "IG-Kin",
    "files": [
      "client/react/dist/**/*",
      "backend/**/*",
      "electron-main.js",
      "preload.js",
      "assets/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/ig-pnc-logo.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets"
    }
  },
  "devDependencies": {
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "rimraf": "^5.0.0"
  }
}
